@model Borrowing
@{
    ViewData["Title"] = "Edit Borrowing";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>✏️ Edit Borrowing</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back to Borrowings</a>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <input asp-for="Id" type="hidden" />

            <div class="mb-3">
                <label asp-for="BookId" class="form-label fw-semibold">Book</label>
                <select asp-for="BookId" asp-items="ViewBag.BookId" class="form-select"></select>
                <span asp-validation-for="BookId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ReaderId" class="form-label fw-semibold">Reader</label>
                <select asp-for="ReaderId" asp-items="ViewBag.ReaderId" class="form-select"></select>
                <span asp-validation-for="ReaderId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="BorrowDate" class="form-label fw-semibold"></label>
                <input asp-for="BorrowDate" class="form-control" type="date" />
                <span asp-validation-for="BorrowDate" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DueDate" class="form-label fw-semibold"></label>
                <input asp-for="DueDate" class="form-control" type="date" />
                <span asp-validation-for="DueDate" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ReturnDate" class="form-label fw-semibold"></label>
                <input asp-for="ReturnDate" class="form-control" type="date" />
                <span asp-validation-for="ReturnDate" class="text-danger small"></span>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="IsReturned" class="form-check-input" />
                <label asp-for="IsReturned" class="form-check-label fw-semibold">Mark as Returned</label>
                <div class="form-text">Checking this will set the return date to today and mark the book as available.</div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
