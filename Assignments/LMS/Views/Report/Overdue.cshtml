@model IEnumerable<Borrowing>
@{
    ViewData["Title"] = "Overdue Report";
    decimal outstanding = (decimal)ViewBag.TotalOutstanding;
    decimal collected   = (decimal)ViewBag.TotalCollected;
    decimal rate        = (decimal)ViewBag.DailyRate;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>⚠️ Overdue &amp; Charges Report</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back to Reports</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-success">🎉 No overdue borrowings. All books are on time!</div>
}
else
{
    <!-- Summary bar -->
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-lg-3">
            <div class="card border-danger h-100">
                <div class="card-body text-center">
                    <div class="display-5 fw-bold text-danger">@Model.Count(b => !b.IsReturned)</div>
                    <div class="text-muted small">Currently Overdue</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card border-warning h-100">
                <div class="card-body text-center">
                    <div class="display-5 fw-bold text-warning">@Model.Count(b => b.IsReturned)</div>
                    <div class="text-muted small">Returned Late</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card border-danger h-100">
                <div class="card-body text-center">
                    <div class="display-5 fw-bold text-danger">$@outstanding.ToString("F2")</div>
                    <div class="text-muted small">Outstanding Fines</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card border-secondary h-100">
                <div class="card-body text-center">
                    <div class="display-5 fw-bold text-secondary">$@collected.ToString("F2")</div>
                    <div class="text-muted small">Late-return Charges</div>
                </div>
            </div>
        </div>
    </div>

    <div class="alert alert-secondary small mb-3">
        <strong>Rate:</strong> $@rate.ToString("F2") per day after the due date.
        Charges accumulate each calendar day until the book is returned.
    </div>

    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Book</th>
                    <th>Reader</th>
                    <th>Due Date</th>
                    <th>Return Date</th>
                    <th class="text-center">Days Overdue</th>
                    <th class="text-end">Fine ($)</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    <tr class="@(!b.IsReturned ? "table-danger" : "table-warning")">
                        <td>@b.Id</td>
                        <td><strong>@(b.Book?.Title ?? $"Book #{b.BookId}")</strong></td>
                        <td>@(b.Reader?.Name ?? $"Reader #{b.ReaderId}")</td>
                        <td class="fw-bold">@b.DueDate.ToString("MMM d, yyyy")</td>
                        <td>@(b.ReturnDate.HasValue ? b.ReturnDate.Value.ToString("MMM d, yyyy") : "Not returned")</td>
                        <td class="text-center fw-bold @(!b.IsReturned ? "text-danger" : "text-warning")">
                            @b.OverdueDays
                        </td>
                        <td class="text-end fw-bold text-danger">$@b.OverdueFee.ToString("F2")</td>
                        <td>
                            @if (!b.IsReturned)
                            {
                                <span class="badge bg-danger">Overdue</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Late Return</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot class="table-light fw-semibold">
                <tr>
                    <td colspan="6" class="text-end">Outstanding fines (not yet returned):</td>
                    <td class="text-end text-danger">$@outstanding.ToString("F2")</td>
                    <td></td>
                </tr>
                <tr>
                    <td colspan="6" class="text-end">Late return charges (already returned):</td>
                    <td class="text-end text-secondary">$@collected.ToString("F2")</td>
                    <td></td>
                </tr>
                <tr>
                    <td colspan="6" class="text-end fw-bold">Total charges:</td>
                    <td class="text-end fw-bold text-danger">$@((outstanding + collected).ToString("F2"))</td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>

    <div class="mt-3 d-flex gap-2">
        <a asp-controller="Borrowing" asp-action="Index" class="btn btn-outline-secondary">Manage Borrowings</a>
    </div>
}
