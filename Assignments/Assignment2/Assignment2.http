@Assignment2_HostAddress = http://localhost:5157

### ========== BOOK ROUTES ==========

### GET all books
GET {{Assignment2_HostAddress}}/api/book
Accept: application/json

###

### GET book by ID
GET {{Assignment2_HostAddress}}/api/book/1
Accept: application/json

###

### POST create book
POST {{Assignment2_HostAddress}}/api/book
Content-Type: application/json

{
  "title": "The Great Gatsby",
  "author": "F. Scott Fitzgerald",
  "isbn": "9780743273565",
  "genre": "Fiction",
  "totalCopies": 5,
  "availableCopies": 3,
  "publishedDate": "1925-04-10",
  "publisher": "Scribner"
}

###

### PUT update book
PUT {{Assignment2_HostAddress}}/api/book/1
Content-Type: application/json

{
  "id": 1,
  "title": "The Great Gatsby (Updated)",
  "author": "F. Scott Fitzgerald",
  "isbn": "9780743273565",
  "genre": "Fiction",
  "totalCopies": 10,
  "availableCopies": 7,
  "publishedDate": "1925-04-10",
  "publisher": "Scribner"
}

###

### DELETE book
DELETE {{Assignment2_HostAddress}}/api/book/1
Accept: application/json

###

### ========== READER ROUTES ==========

### GET all readers
GET {{Assignment2_HostAddress}}/api/reader
Accept: application/json

###

### GET reader by ID
GET {{Assignment2_HostAddress}}/api/reader/1
Accept: application/json

###

### POST create reader
POST {{Assignment2_HostAddress}}/api/reader
Content-Type: application/json

{
  "firstName": "John",
  "lastName": "Doe",
  "email": "john.doe@example.com",
  "phoneNumber": "403-555-0100",
  "membershipNumber": "MEM001",
  "membershipStartDate": "2026-01-01",
  "membershipExpiryDate": "2027-01-01",
  "address": "123 Main St, Calgary, AB",
  "isActive": true
}

###

### PUT update reader
PUT {{Assignment2_HostAddress}}/api/reader/1
Content-Type: application/json

{
  "id": 1,
  "firstName": "John",
  "lastName": "Smith",
  "email": "john.smith@example.com",
  "phoneNumber": "403-555-0101",
  "membershipNumber": "MEM001",
  "membershipStartDate": "2026-01-01",
  "membershipExpiryDate": "2027-06-01",
  "address": "456 Oak Ave, Calgary, AB",
  "isActive": true
}

###

### DELETE reader
DELETE {{Assignment2_HostAddress}}/api/reader/1
Accept: application/json

###

### ========== BORROWING ROUTES ==========

### GET all borrowings
GET {{Assignment2_HostAddress}}/api/borrowing
Accept: application/json

###

### GET borrowing by ID
GET {{Assignment2_HostAddress}}/api/borrowing/1
Accept: application/json

###

### POST create borrowing
POST {{Assignment2_HostAddress}}/api/borrowing
Content-Type: application/json

{
  "bookId": 1,
  "readerId": 1,
  "borrowDate": "2026-03-08",
  "dueDate": "2026-03-22",
  "isReturned": false,
  "overdueCharge": 0,
  "notes": "First borrowing"
}

###

### PUT update borrowing (return book)
PUT {{Assignment2_HostAddress}}/api/borrowing/1
Content-Type: application/json

{
  "id": 1,
  "bookId": 1,
  "readerId": 1,
  "borrowDate": "2026-03-08",
  "dueDate": "2026-03-22",
  "returnDate": "2026-03-20",
  "isReturned": true,
  "overdueCharge": 0,
  "notes": "Returned on time"
}

###

### DELETE borrowing
DELETE {{Assignment2_HostAddress}}/api/borrowing/1
Accept: application/json

###
