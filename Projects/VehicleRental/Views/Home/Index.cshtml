@model IEnumerable<VehicleRental.Models.Reservation>
@{ ViewData["Title"] = "Dashboard"; }

<h2 class="mb-4">&#128664; Dashboard</h2>

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card text-white bg-dark h-100">
            <div class="card-body">
                <div class="fs-2 fw-bold">@ViewBag.TotalVehicles</div>
                <div>Total Vehicles</div>
                <small class="text-white-50">@ViewBag.AvailableVehicles available</small>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card text-white bg-primary h-100">
            <div class="card-body">
                <div class="fs-2 fw-bold">@ViewBag.TotalCustomers</div>
                <div>Total Customers</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card text-white bg-success h-100">
            <div class="card-body">
                <div class="fs-2 fw-bold">@ViewBag.ActiveReservations</div>
                <div>Active Reservations</div>
                <small class="text-white-50">@ViewBag.PendingReservations pending</small>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card text-white bg-warning h-100">
            <div class="card-body">
                <div class="fs-2 fw-bold">$@(((decimal)ViewBag.TotalRevenue).ToString("N2"))</div>
                <div>Total Revenue</div>
                <small class="text-white-50">$@(((decimal)ViewBag.OutstandingBalance).ToString("N2")) outstanding</small>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-2 mb-4">
    <div class="col-auto">
        <a asp-controller="Vehicle" asp-action="Create" class="btn btn-outline-dark btn-sm">+ Add Vehicle</a>
    </div>
    <div class="col-auto">
        <a asp-controller="Customer" asp-action="Create" class="btn btn-outline-primary btn-sm">+ Add Customer</a>
    </div>
    <div class="col-auto">
        <a asp-controller="Reservation" asp-action="Create" class="btn btn-outline-success btn-sm">+ New Reservation</a>
    </div>
    <div class="col-auto">
        <a asp-controller="Report" asp-action="Index" class="btn btn-outline-secondary btn-sm">View Reports</a>
    </div>
</div>

<!-- Recent Reservations -->
<div class="card shadow-sm">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <span>Recent Reservations</span>
        <a asp-controller="Reservation" asp-action="Index" class="btn btn-sm btn-outline-light">View All</a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Customer</th>
                        <th>Vehicle</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td>@r.Id</td>
                            <td>@(r.Customer?.FullName ?? "—")</td>
                            <td>@(r.Vehicle?.DisplayName ?? "—")</td>
                            <td>@r.StartDate.ToString("MMM d, yyyy")</td>
                            <td>@r.EndDate.ToString("MMM d, yyyy")</td>
                            <td>
                                <span class="badge @(r.Status switch {
                                    VehicleRental.Models.ReservationStatus.Active    => "bg-success",
                                    VehicleRental.Models.ReservationStatus.Pending   => "bg-warning text-dark",
                                    VehicleRental.Models.ReservationStatus.Completed => "bg-secondary",
                                    _                                                 => "bg-danger"
                                })">@r.Status</span>
                            </td>
                            <td>
                                <a asp-controller="Reservation" asp-action="Details" asp-route-id="@r.Id"
                                   class="btn btn-sm btn-outline-secondary">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
