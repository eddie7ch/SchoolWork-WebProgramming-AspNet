@{
    ViewData["Title"] = "Reports";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📊 Library Reports</h2>
    <a asp-action="Overdue" class="btn btn-outline-danger">⚠️ View Overdue Report</a>
</div>

<!-- Books Summary -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <h5 class="fw-semibold text-muted text-uppercase" style="font-size:.8rem;letter-spacing:.05rem;">Books</h5>
    </div>
    <div class="col-sm-4">
        <div class="card border-start border-primary border-4 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Total Book Titles</div>
                <div class="display-6 fw-bold text-primary">@ViewBag.TotalBooks</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card border-start border-success border-4 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Available Copies</div>
                <div class="display-6 fw-bold text-success">@ViewBag.AvailableCopies</div>
                <div class="text-muted small">of @ViewBag.TotalCopies total</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card border-start border-warning border-4 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Borrowed Copies</div>
                <div class="display-6 fw-bold text-warning">@((int)ViewBag.TotalCopies - (int)ViewBag.AvailableCopies)
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Readers & Borrowings Summary -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <h5 class="fw-semibold text-muted text-uppercase" style="font-size:.8rem;letter-spacing:.05rem;">Readers &
            Borrowings</h5>
        </div>
        <div class="col-sm-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Registered Readers</div>
                    <div class="display-6 fw-bold">@ViewBag.TotalReaders</div>
                </div>
            </div>
        </div>
        <div class="col-sm-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Total Borrowings</div>
                    <div class="display-6 fw-bold">@ViewBag.TotalBorrowings</div>
                </div>
            </div>
        </div>
        <div class="col-sm-3">
            <div class="card border-start border-primary border-4 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Active Borrowings</div>
                    <div class="display-6 fw-bold text-primary">@ViewBag.ActiveBorrowings</div>
                </div>
            </div>
        </div>
        <div class="col-sm-3">
            <div class="card border-start border-success border-4 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Returned</div>
                    <div class="display-6 fw-bold text-success">@ViewBag.ReturnedBorrowings</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Fines Summary -->
    <div class="row g-3 mb-5">
        <div class="col-12">
            <h5 class="fw-semibold text-muted text-uppercase" style="font-size:.8rem;letter-spacing:.05rem;">Fines</h5>
        </div>
        <div class="col-sm-4">
            <div class="card border-start border-danger border-4 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Overdue Borrowings</div>
                    <div class="display-6 fw-bold text-danger">@ViewBag.OverdueBorrowings</div>
                    @if ((int)ViewBag.OverdueBorrowings > 0)
                    {
                        <a asp-action="Overdue" class="btn btn-sm btn-outline-danger mt-1">View Details</a>
                    }
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card border-start border-danger border-4 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Outstanding Fines</div>
                    <div class="display-6 fw-bold text-danger">$@((decimal)ViewBag.OutstandingFines).ToString("F2")</div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card border-start border-secondary border-4 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Fines Collected (returned late)</div>
                    <div class="display-6 fw-bold text-secondary">$@((decimal)ViewBag.TotalFinesCollected).ToString("F2")
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Top Borrowed Books -->
    @if (ViewBag.TopBooks != null)
    {
        <h5 class="fw-semibold mb-3">Most Borrowed Books</h5>
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Rank</th>
                        <th>Title</th>
                        <th>Author</th>
                        <th>Times Borrowed</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int rank = 1;
                        foreach (dynamic item in ViewBag.TopBooks)
                        {
                            <tr>
                                <td><strong>#@rank</strong></td>
                                <td>@item.Book.Title</td>
                                <td>@item.Book.Author</td>
                                <td><span class="badge bg-primary fs-6">@item.Count</span></td>
                            </tr>
                            rank++;
                        }
                    }
                </tbody>
            </table>
        </div>
    }