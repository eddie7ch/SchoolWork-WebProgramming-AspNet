@model VehicleRental.Models.Reservation
@{ ViewData["Title"] = "Reservation Details"; }

<h2 class="mb-4">Reservation Details</h2>

<div class="card shadow-sm" style="max-width:550px">
    <div class="card-header bg-dark text-white">Reservation #@Model.Id</div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-5">Customer</dt>    <dd class="col-sm-7">@(Model.Customer?.FullName ?? "—")</dd>
            <dt class="col-sm-5">Vehicle</dt>     <dd class="col-sm-7">@(Model.Vehicle?.DisplayName ?? "—")</dd>
            <dt class="col-sm-5">License Plate</dt><dd class="col-sm-7">@(Model.Vehicle?.LicensePlate ?? "—")</dd>
            <dt class="col-sm-5">Start Date</dt>  <dd class="col-sm-7">@Model.StartDate.ToString("MMM d, yyyy")</dd>
            <dt class="col-sm-5">End Date</dt>    <dd class="col-sm-7">@Model.EndDate.ToString("MMM d, yyyy")</dd>
            <dt class="col-sm-5">Rental Days</dt> <dd class="col-sm-7">@Model.RentalDays</dd>
            <dt class="col-sm-5">Status</dt>
            <dd class="col-sm-7">
                <span class="badge @(Model.Status switch {
                    VehicleRental.Models.ReservationStatus.Active    => "bg-success",
                    VehicleRental.Models.ReservationStatus.Pending   => "bg-warning text-dark",
                    VehicleRental.Models.ReservationStatus.Completed => "bg-secondary",
                    _                                                 => "bg-danger"
                })">@Model.Status</span>
            </dd>
            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <dt class="col-sm-5">Notes</dt>
                <dd class="col-sm-7">@Model.Notes</dd>
            }
        </dl>

        @if (ViewBag.Bill is VehicleRental.Models.Bill bill)
        {
            <hr />
            <h6 class="fw-bold">Billing Summary</h6>
            <dl class="row mb-0">
                <dt class="col-sm-5">Base Amount</dt>        <dd class="col-sm-7">$@bill.BaseAmount.ToString("N2")</dd>
                <dt class="col-sm-5">Additional Charges</dt> <dd class="col-sm-7">$@bill.AdditionalCharges.ToString("N2")</dd>
                <dt class="col-sm-5">Tax (@bill.TaxRate%)</dt><dd class="col-sm-7">$@bill.TaxAmount.ToString("N2")</dd>
                <dt class="col-sm-5 fw-bold">Total</dt>      <dd class="col-sm-7 fw-bold">$@bill.TotalAmount.ToString("N2")</dd>
                <dt class="col-sm-5">Paid</dt>
                <dd class="col-sm-7">
                    @if (bill.IsPaid) { <span class="badge bg-success">Paid</span> }
                    else              { <span class="badge bg-warning text-dark">Unpaid</span> }
                </dd>
            </dl>
        }
    </div>
    <div class="card-footer d-flex gap-2">
        <a asp-action="Edit"  asp-route-id="@Model.Id" class="btn btn-primary btn-sm">Edit</a>
        @if (Model.Status != VehicleRental.Models.ReservationStatus.Cancelled &&
             Model.Status != VehicleRental.Models.ReservationStatus.Completed)
        {
            <a asp-action="Cancel" asp-route-id="@Model.Id" class="btn btn-danger btn-sm">Cancel</a>
        }
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back</a>
    </div>
</div>
