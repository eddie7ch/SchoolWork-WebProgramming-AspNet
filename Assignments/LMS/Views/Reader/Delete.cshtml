@model Reader
@{
    ViewData["Title"] = "Delete Reader";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="text-danger">🗑️ Delete Reader</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back to Readers</a>
</div>

<div class="alert alert-danger">
    Are you sure you want to delete reader <strong>@Model.Name</strong>? This action cannot be undone.
</div>

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@Model.Name</dd>

            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.Email</dd>

            <dt class="col-sm-4">Phone</dt>
            <dd class="col-sm-8">@Model.Phone</dd>

            <dt class="col-sm-4">Member Since</dt>
            <dd class="col-sm-8">@Model.MemberSince.ToString("MMM d, yyyy")</dd>
        </dl>

        <form asp-action="Delete" method="post" class="d-flex gap-2">
            <button type="submit" class="btn btn-danger">Yes, Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
