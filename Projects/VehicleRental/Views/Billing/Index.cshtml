@model IEnumerable<VehicleRental.Models.Bill>
@{ ViewData["Title"] = "Billing"; }

<h2 class="mb-3">Billing</h2>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Bill #</th><th>Reservation</th><th>Customer</th><th>Vehicle</th>
                        <th>Base</th><th>Tax</th><th>Extra</th><th>Total</th><th>Status</th><th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model)
                    {
                        <tr>
                            <td>@b.Id</td>
                            <td>#@b.ReservationId</td>
                            <td>@(b.Reservation?.Customer?.FullName ?? "—")</td>
                            <td>@(b.Reservation?.Vehicle?.DisplayName ?? "—")</td>
                            <td>$@b.BaseAmount.ToString("N2")</td>
                            <td>$@b.TaxAmount.ToString("N2")</td>
                            <td>$@b.AdditionalCharges.ToString("N2")</td>
                            <td class="fw-bold">$@b.TotalAmount.ToString("N2")</td>
                            <td>
                                @if (b.IsPaid)
                                { <span class="badge bg-success">Paid</span> }
                                else
                                { <span class="badge bg-warning text-dark">Unpaid</span> }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@b.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                                @if (!b.IsPaid)
                                {
                                    <form asp-action="MarkPaid" asp-route-id="@b.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-success">Mark Paid</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
