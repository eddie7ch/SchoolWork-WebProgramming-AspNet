@model VehicleRental.Models.Vehicle
@{ ViewData["Title"] = "Add Vehicle"; }

<h2 class="mb-4">Add Vehicle</h2>

<div class="card shadow-sm" style="max-width:500px">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Make" class="form-label fw-semibold"></label>
                <input asp-for="Make" class="form-control" />
                <span asp-validation-for="Make" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Model" class="form-label fw-semibold"></label>
                <input asp-for="Model" class="form-control" />
                <span asp-validation-for="Model" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Year" class="form-label fw-semibold"></label>
                <input asp-for="Year" class="form-control" type="number" />
                <span asp-validation-for="Year" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="LicensePlate" class="form-label fw-semibold"></label>
                <input asp-for="LicensePlate" class="form-control" />
                <span asp-validation-for="LicensePlate" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="VehicleType" class="form-label fw-semibold"></label>
                <select asp-for="VehicleType" asp-items="Html.GetEnumSelectList<VehicleRental.Models.VehicleType>()" class="form-select"></select>
            </div>
            <div class="mb-3">
                <label asp-for="DailyRate" class="form-label fw-semibold"></label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input asp-for="DailyRate" class="form-control" type="number" step="0.01" min="0" />
                </div>
                <span asp-validation-for="DailyRate" class="text-danger small"></span>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="IsAvailable" class="form-check-input" />
                <label asp-for="IsAvailable" class="form-check-label"></label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark">Save</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
