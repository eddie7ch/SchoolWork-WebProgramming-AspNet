@model IEnumerable<Borrowing>
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🏠 Dashboard</h2>
    <span class="text-muted">Welcome back, <strong>@Context.Session.GetString("Username")</strong></span>
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="card stat-card stat-card-primary h-100">
            <div class="card-body">
                <div class="text-muted small">Total Books</div>
                <div class="display-6 fw-bold text-primary">@ViewBag.TotalBooks</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card stat-card stat-card-success h-100">
            <div class="card-body">
                <div class="text-muted small">Available Books</div>
                <div class="display-6 fw-bold text-success">@ViewBag.AvailableBooks</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card stat-card stat-card-warning h-100">
            <div class="card-body">
                <div class="text-muted small">Total Readers</div>
                <div class="display-6 fw-bold text-warning">@ViewBag.TotalReaders</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card stat-card stat-card-danger h-100">
            <div class="card-body">
                <div class="text-muted small">Active Borrowings</div>
                <div class="display-6 fw-bold text-danger">@ViewBag.ActiveBorrowings</div>
                @if (ViewBag.OverdueBorrowings > 0)
                {
                    <span class="badge bg-danger">@ViewBag.OverdueBorrowings overdue</span>
                }
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <h5 class="fw-semibold">Quick Actions</h5>
    </div>
    <div class="col-auto">
        <a asp-controller="Book" asp-action="Create" class="btn btn-outline-primary">+ Add Book</a>
    </div>
    <div class="col-auto">
        <a asp-controller="Reader" asp-action="Create" class="btn btn-outline-success">+ Add Reader</a>
    </div>
    <div class="col-auto">
        <a asp-controller="Borrowing" asp-action="Create" class="btn btn-outline-warning">+ New Borrowing</a>
    </div>
</div>

<!-- Recent Borrowings -->
<h5 class="fw-semibold mb-3">Recent Borrowings</h5>
@if (!Model.Any())
{
    <p class="text-muted">No borrowing records yet.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Book</th>
                    <th>Reader</th>
                    <th>Borrow Date</th>
                    <th>Due Date</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    var isOverdue = !b.IsReturned && b.DueDate < DateTime.Today;
                    <tr class="@(isOverdue ? "table-danger" : "")">
                        <td>@(b.Book?.Title ?? $"Book #{b.BookId}")</td>
                        <td>@(b.Reader?.Name ?? $"Reader #{b.ReaderId}")</td>
                        <td>@b.BorrowDate.ToString("MMM d, yyyy")</td>
                        <td>@b.DueDate.ToString("MMM d, yyyy")</td>
                        <td>
                            @if (b.IsReturned)      { <span class="badge bg-success">Returned</span> }
                            else if (isOverdue)     { <span class="badge bg-danger">Overdue</span> }
                            else                    { <span class="badge bg-primary">Active</span> }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <a asp-controller="Borrowing" asp-action="Index" class="btn btn-sm btn-outline-secondary">View all borrowings →</a>
}

