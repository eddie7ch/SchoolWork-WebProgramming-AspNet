@model IEnumerable<Borrowing>
@{
    ViewData["Title"] = "Borrowing Report — Results";
    var filter = (BorrowingReportFilter)ViewBag.Filter;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📋 Borrowing Report Results</h2>
    <div class="d-flex gap-2">
        <a asp-action="Borrowings" class="btn btn-outline-primary">← Change Filters</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Reports Home</a>
    </div>
</div>

<!-- Active filter summary -->
<div class="alert alert-light border mb-3">
    <strong>Filters applied:</strong>
    @if (filter.FromDate.HasValue)   { <span class="badge bg-secondary me-1">From: @filter.FromDate.Value.ToString("MMM d, yyyy")</span> }
    @if (filter.ToDate.HasValue)     { <span class="badge bg-secondary me-1">To: @filter.ToDate.Value.ToString("MMM d, yyyy")</span> }
    @if (filter.Status != "all")     { <span class="badge bg-primary me-1">Status: @filter.Status</span> }
    @if (filter.ReaderId > 0)        { <span class="badge bg-info text-dark me-1">Reader filtered</span> }
    @if (filter.BookId > 0)          { <span class="badge bg-info text-dark me-1">Book filtered</span> }
    — <strong>@Model.Count()</strong> record(s) found
    @if ((decimal)ViewBag.TotalFees > 0)
    {
        <span class="ms-3 text-danger fw-semibold">Total overdue charges in results: $@((decimal)ViewBag.TotalFees).ToString("F2")</span>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No borrowings match the selected filters.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Book</th>
                    <th>Reader</th>
                    <th>Borrow Date</th>
                    <th>Due Date</th>
                    <th>Return Date</th>
                    <th>Status</th>
                    <th class="text-end">Fine ($)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    <tr class="@(b.IsOverdue ? "table-danger" : "")">
                        <td>@b.Id</td>
                        <td>@(b.Book?.Title ?? $"Book #{b.BookId}")</td>
                        <td>@(b.Reader?.Name ?? $"Reader #{b.ReaderId}")</td>
                        <td>@b.BorrowDate.ToString("MMM d, yyyy")</td>
                        <td class="@(b.IsOverdue ? "fw-bold" : "")">@b.DueDate.ToString("MMM d, yyyy")</td>
                        <td>@(b.ReturnDate.HasValue ? b.ReturnDate.Value.ToString("MMM d, yyyy") : "—")</td>
                        <td>
                            @if (b.IsReturned && b.OverdueFee > 0)
                            {
                                <span class="badge bg-warning text-dark">Late Return</span>
                            }
                            else if (b.IsReturned)
                            {
                                <span class="badge bg-success">Returned</span>
                            }
                            else if (b.IsOverdue)
                            {
                                <span class="badge bg-danger">Overdue (@b.OverdueDays d)</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">Active</span>
                            }
                        </td>
                        <td class="text-end @(b.OverdueFee > 0 ? "text-danger fw-semibold" : "text-muted")">
                            @(b.OverdueFee > 0 ? $"${b.OverdueFee:F2}" : "—")
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot class="table-light fw-semibold">
                <tr>
                    <td colspan="7" class="text-end">Total overdue charges:</td>
                    <td class="text-end text-danger">$@((decimal)ViewBag.TotalFees).ToString("F2")</td>
                </tr>
            </tfoot>
        </table>
    </div>
}
