@model IEnumerable<VehicleRental.Models.Customer>
@{ ViewData["Title"] = "Customers"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Customer Management</h2>
    <a asp-action="Create" class="btn btn-dark">+ Add Customer</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th><th>Name</th><th>Email</th><th>Phone</th>
                        <th>License #</th><th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td>@c.Id</td>
                            <td>@c.FullName</td>
                            <td>@c.Email</td>
                            <td>@c.Phone</td>
                            <td>@c.LicenseNumber</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                                <a asp-action="Edit"    asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                <a asp-action="Delete"  asp-route-id="@c.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
