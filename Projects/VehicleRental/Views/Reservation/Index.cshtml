@model IEnumerable<VehicleRental.Models.Reservation>
@{ ViewData["Title"] = "Reservations"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Reservations</h2>
    <a asp-action="Create" class="btn btn-dark">+ New Reservation</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th><th>Customer</th><th>Vehicle</th>
                        <th>Start</th><th>End</th><th>Days</th><th>Status</th><th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td>@r.Id</td>
                            <td>@(r.Customer?.FullName ?? "—")</td>
                            <td>@(r.Vehicle?.DisplayName ?? "—")</td>
                            <td>@r.StartDate.ToString("MMM d, yyyy")</td>
                            <td>@r.EndDate.ToString("MMM d, yyyy")</td>
                            <td>@r.RentalDays</td>
                            <td>
                                <span class="badge @(r.Status switch {
                                    VehicleRental.Models.ReservationStatus.Active    => "bg-success",
                                    VehicleRental.Models.ReservationStatus.Pending   => "bg-warning text-dark",
                                    VehicleRental.Models.ReservationStatus.Completed => "bg-secondary",
                                    _                                                 => "bg-danger"
                                })">@r.Status</span>
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@r.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                                <a asp-action="Edit"    asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                @if (r.Status != VehicleRental.Models.ReservationStatus.Cancelled &&
                                     r.Status != VehicleRental.Models.ReservationStatus.Completed)
                                {
                                    <a asp-action="Cancel" asp-route-id="@r.Id" class="btn btn-sm btn-outline-danger">Cancel</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
