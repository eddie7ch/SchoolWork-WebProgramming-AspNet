@model Book
@{
    ViewData["Title"] = "Add Book";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📖 Add New Book</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back to Books</a>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-semibold"></label>
                <input asp-for="Title" class="form-control" placeholder="e.g. The Great Gatsby" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Author" class="form-label fw-semibold"></label>
                <input asp-for="Author" class="form-control" placeholder="e.g. F. Scott Fitzgerald" />
                <span asp-validation-for="Author" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ISBN" class="form-label fw-semibold"></label>
                <input asp-for="ISBN" class="form-control" placeholder="e.g. 9780743273565" />
                <span asp-validation-for="ISBN" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Genre" class="form-label fw-semibold"></label>
                <input asp-for="Genre" class="form-control" placeholder="e.g. Fiction, Technology, Science" />
                <span asp-validation-for="Genre" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PublishedYear" class="form-label fw-semibold"></label>
                <input asp-for="PublishedYear" class="form-control" type="number" />
                <span asp-validation-for="PublishedYear" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TotalCopies" class="form-label fw-semibold"></label>
                <input asp-for="TotalCopies" class="form-control" type="number" min="1" />
                <span asp-validation-for="TotalCopies" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="AvailableCopies" class="form-label fw-semibold"></label>
                <input asp-for="AvailableCopies" class="form-control" type="number" min="0" />
                <span asp-validation-for="AvailableCopies" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Book</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
