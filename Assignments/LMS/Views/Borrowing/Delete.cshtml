@model Borrowing
@{
    ViewData["Title"] = "Delete Borrowing";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="text-danger">🗑️ Delete Borrowing</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back to Borrowings</a>
</div>

<div class="alert alert-danger">
    Are you sure you want to delete this borrowing record? This action cannot be undone.
    @if (!Model.IsReturned)
    {
        <br /><text><strong>Note:</strong> The book will be marked as available again.</text>
    }
</div>

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Book</dt>
            <dd class="col-sm-8">@(Model.Book?.Title ?? $"Book #{Model.BookId}")</dd>

            <dt class="col-sm-4">Reader</dt>
            <dd class="col-sm-8">@(Model.Reader?.Name ?? $"Reader #{Model.ReaderId}")</dd>

            <dt class="col-sm-4">Borrow Date</dt>
            <dd class="col-sm-8">@Model.BorrowDate.ToString("MMM d, yyyy")</dd>

            <dt class="col-sm-4">Due Date</dt>
            <dd class="col-sm-8">@Model.DueDate.ToString("MMM d, yyyy")</dd>

            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">@(Model.IsReturned ? "Returned" : "Not Returned")</dd>
        </dl>

        <form asp-action="Delete" method="post" class="d-flex gap-2">
            <button type="submit" class="btn btn-danger">Yes, Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
