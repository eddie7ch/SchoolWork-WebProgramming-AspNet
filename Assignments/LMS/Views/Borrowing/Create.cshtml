@model Borrowing
@{
    ViewData["Title"] = "New Borrowing";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>🔄 New Borrowing</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back to Borrowings</a>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="BookId" class="form-label fw-semibold">Book</label>
                <select asp-for="BookId" asp-items="ViewBag.BookId" class="form-select">
                    <option value="">— Select an available book —</option>
                </select>
                <span asp-validation-for="BookId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ReaderId" class="form-label fw-semibold">Reader</label>
                <select asp-for="ReaderId" asp-items="ViewBag.ReaderId" class="form-select">
                    <option value="">— Select a reader —</option>
                </select>
                <span asp-validation-for="ReaderId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="BorrowDate" class="form-label fw-semibold"></label>
                <input asp-for="BorrowDate" class="form-control" type="date" />
                <span asp-validation-for="BorrowDate" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DueDate" class="form-label fw-semibold"></label>
                <input asp-for="DueDate" class="form-control" type="date" />
                <span asp-validation-for="DueDate" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Create Borrowing</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
