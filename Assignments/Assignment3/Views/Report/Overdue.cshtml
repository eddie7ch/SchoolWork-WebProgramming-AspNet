@model IEnumerable<LMS.Models.Borrowing>
@{
    ViewData["Title"] = "Overdue Report";
    var totalFines = Model.Sum(b => b.OverdueFee);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>⚠️ Overdue Report</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back to Reports</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-success">
        <strong>No overdue borrowings!</strong> All active borrowings are within their due dates.
    </div>
}
else
{
    <div class="alert alert-danger d-flex align-items-center gap-3 mb-4">
        <div>
            <strong>@Model.Count() overdue borrowing(s) found.</strong>
            Total outstanding fines: <span class="fs-5 fw-bold">$@totalFines.ToString("F2")</span>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Book</th>
                    <th>Reader</th>
                    <th>Borrow Date</th>
                    <th>Due Date</th>
                    <th class="text-center">Days Overdue</th>
                    <th class="text-end">Fine ($)</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    <tr class="table-danger">
                        <td>@b.Id</td>
                        <td><strong>@(b.Book?.Title ?? $"Book #{b.BookId}")</strong></td>
                        <td>@(b.Reader?.Name ?? $"Reader #{b.ReaderId}")</td>
                        <td>@b.BorrowDate.ToString("MMM d, yyyy")</td>
                        <td class="fw-bold text-danger">@b.DueDate.ToString("MMM d, yyyy")</td>
                        <td class="text-center">
                            <span class="badge bg-danger fs-6">@b.OverdueDays days</span>
                        </td>
                        <td class="text-end fw-bold text-danger">$@b.OverdueFee.ToString("F2")</td>
                        <td class="text-center">
                            <a asp-controller="Borrowing" asp-action="Edit" asp-route-id="@b.Id"
                               class="btn btn-sm btn-outline-primary">Mark Returned</a>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot class="table-light fw-bold">
                <tr>
                    <td colspan="6" class="text-end">Total Outstanding Fines:</td>
                    <td class="text-end text-danger">$@totalFines.ToString("F2")</td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>
}