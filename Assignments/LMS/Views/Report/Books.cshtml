@model IEnumerable<Book>
@{
    ViewData["Title"] = "Book Usage Report";
    var borrowCounts = (Dictionary<int, int>)ViewBag.BorrowCounts;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📖 Book Usage Report</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back to Reports</a>
</div>

<div class="table-responsive">
    <table class="table table-hover table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th>Published</th>
                <th>ISBN</th>
                <th class="text-center">Times Borrowed</th>
                <th>Availability</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in Model.OrderByDescending(b => borrowCounts.GetValueOrDefault(b.Id, 0)))
            {
                var count = borrowCounts.GetValueOrDefault(book.Id, 0);
                <tr>
                    <td><strong>@book.Title</strong></td>
                    <td>@book.Author</td>
                    <td>@book.PublishedYear</td>
                    <td><code>@book.ISBN</code></td>
                    <td class="text-center">
                        <span class="badge bg-primary rounded-pill fs-6">@count</span>
                    </td>
                    <td>
                        @if (book.IsAvailable)
                        {
                            <span class="badge bg-success">Available</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Borrowed</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
