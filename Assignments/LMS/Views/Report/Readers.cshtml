@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Reader Activity Report";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>👥 Reader Activity Report</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back to Reports</a>
</div>

<div class="table-responsive">
    <table class="table table-hover table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th>Reader</th>
                <th>Email</th>
                <th>Member Since</th>
                <th class="text-center">Total Borrows</th>
                <th class="text-center">Active</th>
                <th class="text-center">Overdue</th>
                <th class="text-end">Outstanding Fine</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model)
            {
                Reader r = row.Reader;
                int total    = row.TotalBorrows;
                int active   = row.ActiveBorrows;
                int overdue  = row.OverdueBorrows;
                decimal fine = row.OutstandingFines;
                <tr class="@(overdue > 0 ? "table-warning" : "")">
                    <td><strong>@r.Name</strong></td>
                    <td><a href="mailto:@r.Email">@r.Email</a></td>
                    <td>@r.MemberSince.ToString("MMM d, yyyy")</td>
                    <td class="text-center">@total</td>
                    <td class="text-center">@active</td>
                    <td class="text-center">
                        @if (overdue > 0)
                        {
                            <span class="badge bg-danger">@overdue</span>
                        }
                        else
                        {
                            <span class="text-muted">0</span>
                        }
                    </td>
                    <td class="text-end @(fine > 0 ? "text-danger fw-semibold" : "text-muted")">
                        @(fine > 0 ? $"${fine:F2}" : "—")
                    </td>
                </tr>
            }
        </tbody>
        <tfoot class="table-light fw-semibold">
            @{
                decimal totalFines = 0;
                foreach (var row in Model) { totalFines += (decimal)row.OutstandingFines; }
            }
            <tr>
                <td colspan="6" class="text-end">Total outstanding fines:</td>
                <td class="text-end text-danger">$@totalFines.ToString("F2")</td>
            </tr>
        </tfoot>
    </table>
</div>
