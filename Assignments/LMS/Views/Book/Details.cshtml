@model Book
@{
    ViewData["Title"] = "Book Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📖 Book Details</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back to Books</a>
</div>

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Title</dt>
            <dd class="col-sm-8"><strong>@Model.Title</strong></dd>

            <dt class="col-sm-4">Author</dt>
            <dd class="col-sm-8">@Model.Author</dd>

            <dt class="col-sm-4">ISBN</dt>
            <dd class="col-sm-8"><code>@Model.ISBN</code></dd>

            <dt class="col-sm-4">Published Year</dt>
            <dd class="col-sm-8">@Model.PublishedYear</dd>

            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">
                @if (Model.IsAvailable)
                {
                    <span class="badge bg-success fs-6">Available</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark fs-6">Borrowed</span>
                }
            </dd>
        </dl>

        <div class="d-flex gap-2 mt-3">
            <a asp-action="Edit"   asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete</a>
        </div>
    </div>
</div>
