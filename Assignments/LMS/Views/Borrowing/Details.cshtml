@model Borrowing
@{
    ViewData["Title"] = "Borrowing Details";
    var isOverdue = !Model.IsReturned && Model.DueDate < DateTime.Today;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>🔄 Borrowing Details</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back to Borrowings</a>
</div>

@if (isOverdue)
{
    <div class="alert alert-danger">⚠️ This borrowing is <strong>overdue</strong> by @((DateTime.Today - Model.DueDate).Days) day(s).</div>
}

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Book</dt>
            <dd class="col-sm-8"><strong>@(Model.Book?.Title ?? $"Book #{Model.BookId}")</strong></dd>

            <dt class="col-sm-4">Reader</dt>
            <dd class="col-sm-8">@(Model.Reader?.Name ?? $"Reader #{Model.ReaderId}")</dd>

            <dt class="col-sm-4">Borrow Date</dt>
            <dd class="col-sm-8">@Model.BorrowDate.ToString("MMMM d, yyyy")</dd>

            <dt class="col-sm-4">Due Date</dt>
            <dd class="col-sm-8 @(isOverdue ? "text-danger fw-bold" : "")">@Model.DueDate.ToString("MMMM d, yyyy")</dd>

            <dt class="col-sm-4">Return Date</dt>
            <dd class="col-sm-8">@(Model.ReturnDate.HasValue ? Model.ReturnDate.Value.ToString("MMMM d, yyyy") : "Not returned yet")</dd>

            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">
                @if (Model.IsReturned)
                {
                    <span class="badge bg-success fs-6">Returned</span>
                }
                else if (isOverdue)
                {
                    <span class="badge bg-danger fs-6">Overdue</span>
                }
                else
                {
                    <span class="badge bg-primary fs-6">Active</span>
                }
            </dd>
        </dl>

        <div class="d-flex gap-2 mt-3">
            <a asp-action="Edit"   asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete</a>
        </div>
    </div>
</div>
