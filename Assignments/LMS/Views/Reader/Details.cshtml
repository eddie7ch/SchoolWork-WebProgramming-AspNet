@model Reader
@{
    ViewData["Title"] = "Reader Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>👤 Reader Details</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back to Readers</a>
</div>

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8"><strong>@Model.Name</strong></dd>

            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8"><a href="mailto:@Model.Email">@Model.Email</a></dd>

            <dt class="col-sm-4">Phone</dt>
            <dd class="col-sm-8">@Model.Phone</dd>

            <dt class="col-sm-4">Member Since</dt>
            <dd class="col-sm-8">@Model.MemberSince.ToString("MMMM d, yyyy")</dd>
        </dl>

        <div class="d-flex gap-2 mt-3">
            <a asp-action="Edit"   asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete</a>
        </div>
    </div>
</div>
